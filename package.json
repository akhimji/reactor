{
  "name": "reactor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reactor — premium indie reactor sim. Sustain-don't-die.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @reactor/game run dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
